rules_version = '2';

// Firestore security rules for the Hostel Management app.
//
// ACTIVE ruleset = role-aware. Owners manage everything; tenants and staff can
// only touch what they should (their own bills, their own attendance, the
// complaints assigned to them, etc.). Everything requires sign-in.
//
// Deploy from the Firebase console (Firestore -> Rules) or the CLI:
//   firebase deploy --only firestore:rules
//
// If you ever get locked out while testing, temporarily swap the whole block
// for the permissive fallback at the very bottom (commented).
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function hasProfile() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    function myUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function isOwner() { return hasProfile() && myUser().role == 'owner'; }
    function myLinkedId() { return hasProfile() ? myUser().linkedId : ''; }

    // A user manages their own users/{uid} doc (written at signup / when the
    // owner provisions them); any signed-in user may read profiles.
    match /users/{uid} {
      allow read: if signedIn();
      allow create, update: if request.auth.uid == uid || isOwner();
      allow delete: if isOwner();
    }

    // Hostel structure & directories: owner writes, signed-in users read.
    match /blocks/{id}   { allow read: if signedIn(); allow write: if isOwner(); }
    match /floors/{id}   { allow read: if signedIn(); allow write: if isOwner(); }
    match /rooms/{id}    { allow read: if signedIn(); allow write: if isOwner(); }
    match /beds/{id}     { allow read: if signedIn(); allow write: if isOwner(); }
    match /tenants/{id}  { allow read: if signedIn(); allow write: if isOwner(); }
    match /staff/{id}    { allow read: if signedIn(); allow write: if isOwner(); }
    match /expenses/{id} { allow read, write: if isOwner(); }
    match /menus/{id}    { allow read: if signedIn(); allow write: if isOwner(); }
    match /notices/{id}  { allow read: if signedIn(); allow write: if isOwner(); }

    // Payments: owner manages; a tenant may mark their own bill paid.
    match /payments/{id} {
      allow read: if signedIn();
      allow create, delete: if isOwner();
      allow update: if isOwner() || resource.data.tenantId == myLinkedId();
    }

    // Complaints: tenant raises; owner assigns; assigned staff updates status.
    match /complaints/{id} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if isOwner() || resource.data.assignedStaffId == myLinkedId();
      allow delete: if isOwner();
    }

    // Tenant-authored content.
    match /ratings/{id} {
      allow read: if signedIn();
      allow create: if signedIn();
    }
    match /amenityBookings/{id} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow delete: if isOwner() || resource.data.tenantId == myLinkedId();
    }
    match /requests/{id} {
      allow read: if isOwner();
      allow create: if signedIn();
      allow update: if isOwner();
    }

    // Attendance: staff writes their own rows; owner can read/write all.
    match /attendance/{id} {
      allow read: if signedIn();
      allow write: if isOwner()
        || request.resource.data.personId == myLinkedId()
        || (resource != null && resource.data.personId == myLinkedId());
    }

    // ---- PERMISSIVE FALLBACK (commented) --------------------------------
    // If the rules above ever block the app during testing, replace everything
    // inside `match /databases/{database}/documents { ... }` with just:
    //   match /{document=**} { allow read, write: if request.auth != null; }
  }
}
